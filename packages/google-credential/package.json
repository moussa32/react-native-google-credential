{
  "name": "@pricava/react-native-google-credential",
  "version": "1.0.0",
  "description": "React Native-first Google credential sign-in with Expo support.",
  "license": "MIT",
  "author": "Moussa Ibrahim",
  "homepage": "https://github.com/moussa32/react-native-google-credential#readme",
  "bugs": {
    "url": "https://github.com/moussa32/react-native-google-credential/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/moussa32/react-native-google-credential.git",
    "directory": "packages/google-credential"
  },
  "main": "./src/index.ts",
  "react-native": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./adapters": {
      "react-native": "./src/adapters/index.ts",
      "default": "./src/adapters/index.ts"
    },
    "./adapters/clerk": {
      "react-native": "./src/adapters/clerk.ts",
      "default": "./src/adapters/clerk.ts"
    },
    "./adapters/firebase": {
      "react-native": "./src/adapters/firebase.ts",
      "default": "./src/adapters/firebase.ts"
    },
    "./adapters/supabase": {
      "react-native": "./src/adapters/supabase.ts",
      "default": "./src/adapters/supabase.ts"
    },
    "./app.plugin": "./app.plugin.js",
    "./package.json": "./package.json"
  },
  "codegenConfig": {
    "name": "PricavaGoogleCredentialSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "android": {
      "javaPackageName": "com.pricava.googlecredential"
    },
    "ios": {
      "modules": {
        "PricavaGoogleCredential": {
          "className": "PricavaGoogleCredential"
        }
      }
    }
  },
  "files": [
    "android",
    "ios",
    "plugin",
    "src",
    "adapters.ts",
    "app.plugin.js",
    "react-native.config.js",
    "index.ts",
    "README.md",
    "IMPLEMENTATION.md"
  ],
  "scripts": {
    "lint": "echo \"TODO: add package lint\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {},
  "peerDependencies": {
    "@react-native-firebase/auth": "^24.1.1",
    "react": "*",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "@react-native-firebase/auth": {
      "optional": true
    }
  },
  "devDependencies": {
    "@react-native-firebase/auth": "^24.1.1",
    "typescript": "^6.0.3"
  }
}
